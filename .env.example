BOT_TOKEN=123456:replace_me
OWNER_USER_ID=123456789
SUPPORT_USERNAME=mattersless
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: where to store runtime data on server
DATA_DIR=./data

# Optional: use if you want custom file paths
# SESSIONS_DIR=./data/sessions
# ACCOUNTS_FILE=./data/accounts.json
# ACCESS_USERS_FILE=./data/access_users.json
# LOGS_DIR=./data/logs

# Optional: bot will use these values when importing .session without explicit api_id/api_hash
DEFAULT_API_ID=12345
DEFAULT_API_HASH=replace_me

# Optional: notifications can go to another Telegram ID
# HEALTH_NOTIFY_CHAT_ID=123456789

MIN_DELAY_SECONDS=2
MAX_COUNT=100
MAX_RETRIES=3

# Policy links for first-login inline buttons
USAGE_POLICY_URL=https://example.com/usage
PRIVACY_POLICY_URL=https://example.com/privacy
TERMS_OF_SERVICE_URL=https://example.com/terms

# Admin API embedded in python runtime
ADMIN_API_ENABLED=true
ADMIN_API_HOST=0.0.0.0
ADMIN_API_TOKEN=replace_with_long_random_secret
# On Render, you can omit this and PORT will be used automatically.
# ADMIN_API_PORT=8000
